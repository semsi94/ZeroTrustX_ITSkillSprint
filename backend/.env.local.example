# ZeroTrustX local host-mode environment
# Copy this file to backend/.env when running without Docker.

# --- App ---
APP_VERSION=1.0.0
JWT_SECRET_KEY=change-me-to-a-long-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
MFA_DAILY_REQUIRED=true
SEED_ADMIN_PASSWORD=
SEED_ANALYST_PASSWORD=
SEED_VIEWER_PASSWORD=
DEMO_MODE=false
DEMO_SEED_ON_START=false
DEMO_RESET_ON_START=false
DEMO_USER_AUTOLOGIN=false

# --- Local PostgreSQL ---
# Async driver for FastAPI runtime, sync driver for Alembic migrations and Celery sync jobs.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dashboard_v3
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/dashboard_v3

# --- Local Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Splunk ---
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false
SPLUNK_DEFAULT_INDEX=*
SPLUNK_DEFAULT_LIMIT=100
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_URL=

# --- pfSense ---
PFSENSE_HOST=
PFSENSE_USERNAME=
PFSENSE_PASSWORD=
PFSENSE_BLOCK_ALIAS=
PFSENSE_VERIFY_SSL=false
PFSENSE_CA_CERT_PATH=
PFSENSE_CA_CERT_TEXT=
PFSENSE_TIMEOUT=10

# --- Reputation Intelligence ---
IP_REPUTATION_ENABLED=true
IP_REPUTATION_AUTO_INCIDENT_ENABLED=true
IP_REPUTATION_MAX_REQUESTS_PER_MINUTE=50
IP_REPUTATION_DEFAULT_CACHE_HOURS=24
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
