# ZeroTrustX Environment Configuration
# Copy to .env and fill in values for the integrations you want enabled.

# --- App ---
APP_VERSION=1.0.0
# Generate a long random string (openssl rand -hex 32) for JWT signing.
JWT_SECRET_KEY=change-me-to-a-long-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Only these direct source networks may supply X-Forwarded-For/X-Real-IP.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,172.18.0.0/16
MFA_DAILY_REQUIRED=true
# Lab seed users are admin/mammadov4103@gmail.com, analyst/analyst@example.local, viewer/viewer@example.local.
# Leave blank to create disabled seed profiles.
SEED_ADMIN_PASSWORD=<admin_password>
SEED_ANALYST_PASSWORD=<analyst_password>
SEED_VIEWER_PASSWORD=<viewer_password>
DEMO_MODE=false
DEMO_SEED_ON_START=false
DEMO_RESET_ON_START=false
DEMO_USER_AUTOLOGIN=false

# --- Database ---
# Async driver (asyncpg) for runtime, sync driver for Alembic migrations.
DATABASE_URL=postgresql+asyncpg://zerotrustx:zerotrustx_pw@postgres:5432/zerotrustx
DATABASE_URL_SYNC=postgresql+psycopg2://zerotrustx:zerotrustx_pw@postgres:5432/zerotrustx

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Splunk (SIEM) ---
# Management API is used for investigation/search on port 8089.
# HEC is optional and is only used for write-back audit events.
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false
SPLUNK_DEFAULT_INDEX=*
SPLUNK_DEFAULT_LIMIT=100
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_URL=

# --- pfSense (Firewall) ---
# Leave empty to run without pfSense. All fields required to enable the integration.
PFSENSE_HOST=
PFSENSE_USERNAME=
PFSENSE_PASSWORD=
# Alias name on pfSense that ZeroTrustX writes blocked IPs into. Must exist on pfSense.
PFSENSE_BLOCK_ALIAS=
PFSENSE_VERIFY_SSL=false
PFSENSE_CA_CERT_PATH=
PFSENSE_CA_CERT_TEXT=
PFSENSE_TIMEOUT=10

# --- Reputation Intelligence ---
# Both providers are required for full IP reputation enrichment. Keys are stored encrypted by the Settings UI.
IP_REPUTATION_ENABLED=true
IP_REPUTATION_AUTO_INCIDENT_ENABLED=true
IP_REPUTATION_MAX_REQUESTS_PER_MINUTE=50
IP_REPUTATION_DEFAULT_CACHE_HOURS=24
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
