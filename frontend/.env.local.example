# ZeroTrustX local host-mode frontend environment
# Copy this file to frontend/.env.local when running without Docker.

# The Axios API client uses this direct backend URL.
VITE_API_URL=http://localhost:8000

# Vite dev-server proxy for calls made to /api/* from the browser.
# Vite strips /api before forwarding to FastAPI.
VITE_API_PROXY_TARGET=http://localhost:8000
